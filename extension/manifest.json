{
  "manifest_version": 3,
  "name": "ClipTap",
  "version": "1.1.1",
  "description": "YouTube 플레이어 안에서 시작/끝 지점을 찍고 yt-dlp로 구간 다운로드합니다.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://youtu.be/*",
    "http://127.0.0.1:17723/*",
    "http://localhost:17723/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtu.be/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ClipTap",
    "default_popup": "popup.html"
  }
}
