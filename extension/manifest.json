{
  "manifest_version": 3,
  "name": "ClipTap",
  "version": "1.1.4",
  "description": "YouTube 플레이어 안에서 구간 또는 전체 영상을 yt-dlp로 다운로드합니다.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://youtu.be/*",
    "http://127.0.0.1:17723/*",
    "http://localhost:17723/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtu.be/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ClipTap",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/cliptap.png",
      "128": "icons/cliptap.png"
    }
  },
  "icons": {
    "48": "icons/cliptap.png",
    "128": "icons/cliptap.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/cliptap.png"
      ],
      "matches": [
        "*://*.youtube.com/*",
        "*://youtu.be/*"
      ]
    }
  ]
}
